     <!--ls:begin[component-1502770494161]--><div class="component noMargin txtOnly idol-index">
   <h1 class="componentTitle">Space Availability</h1>
   <div class="row">
      <div class="col-md-12 col-sm-12 col-xs-12 box ani">
         <p>Passengers may check the number of parking spaces available at Car Park 1, Car Park
            2 and Car Park 4 of Hong Kong International Airport.
         </p>
         <div class="specialAnnouncement icon-important-notice-sign">
            <p id="sp"><strong>Special Notice:&nbsp;</strong><span></span></p>
         </div>
      </div>
   </div>
</div>
